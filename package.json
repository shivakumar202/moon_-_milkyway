{
  "name": "moon",
  "version": "1.0.0",
  "private": true,
  "devDependencies": {
    "tailwindcss": "^3.4.6",
    "postcss": "^8.4.24",
    "autoprefixer": "^10.4.14"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "dev": "npm run watch:css",
    "start": "py -3 -m http.server 8000"
  }
}
